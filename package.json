{
  "name": "huginn",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "bin": {
    "warden": "./bin/warden.js"
  },
  "scripts": {
    "test": "vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "husky",
    "db:up": "docker compose up -d",
    "db:push": "drizzle-kit push",
    "dev:backend": "set WARDEN_OFFLINE_BYPASS=true&& tsx --watch src/index.ts",
    "dev:frontend": "npm --prefix ui run dev",
    "start": "npm run db:up && concurrently \"npm run dev:backend\" \"npm run dev:frontend\""
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/pg": "^8.20.0",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@types/ws": "^8.18.1",
    "bullmq": "^5.79.2",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "pg": "^8.22.0",
    "ws": "^8.21.0",
    "zod": "^4.4.3"
  },
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,md,yml,yaml,html,css}": "prettier --write",
    "*.ts": "eslint --fix"
  }
}
